# BareBonesForms — Security Rules
# These rules work on Apache with mod_rewrite and AllowOverride All.
#
# ─── Nginx equivalent (add to your server block) ──────────────
# location ~ ^/config        { deny all; return 403; }
# location ~ ^/(submissions|logs|templates|actions|backups|tests|lang)/ { deny all; return 403; }
# location ~ /forms/.*\.json$ { deny all; return 403; }
# location ~ /\.(git|env|htaccess|htpasswd) { deny all; return 403; }
# autoindex off;
# ───────────────────────────────────────────────────────────────

# Disable directory listing globally
Options -Indexes

# Block all config files — config.php, config.example.php,
# and editor backups: config.php~, config.php.bak, .config.php.swp, etc.
<FilesMatch "^config">
    Require all denied
</FilesMatch>

# Block editor backup and temp files (any file)
# Catches: file.php~, file.bak, file.swp, file.save, file.orig, #file#
<FilesMatch "\.(bak|swp|save|orig|old)$|\.bak-|~$|^#.*#$">
    Require all denied
</FilesMatch>

RewriteEngine On

# Block all dot-files and dot-directories (.git, .env, .htpasswd, etc.)
RewriteRule (^|/)\. - [F,L]

# Block sensitive directories
RewriteRule ^submissions/ - [F,L]
RewriteRule ^logs/ - [F,L]
RewriteRule ^templates/ - [F,L]
RewriteRule ^actions/ - [F,L]
RewriteRule ^backups/ - [F,L]
RewriteRule ^tests/ - [F,L]

# Block direct access to form JSON definitions and lang PHP files
# (forms are served via submit.php?action=definition, lang via include)
RewriteRule ^forms/.*\.json$ - [F,L]
RewriteRule ^lang/.*\.php$ - [F,L]
