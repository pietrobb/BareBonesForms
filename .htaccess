# BareBonesForms — Protect sensitive files and directories
# These rules work on Apache with mod_rewrite enabled.
#
# ─── Nginx equivalent (add to your server block) ──────────────
# location ~ ^/config        { deny all; return 403; }
# location ~ \.(bak|swp|save|orig|old)$ { deny all; return 403; }
# location ~ ~$              { deny all; return 403; }
# location ~ /\.git          { deny all; return 403; }
# location ~ ^/submissions/  { deny all; return 403; }
# location ~ ^/logs/         { deny all; return 403; }
# ───────────────────────────────────────────────────────────────

# Block all config files — config.php, config.example.php,
# and editor backups: config.php~, config.php.bak, .config.php.swp, etc.
<FilesMatch "^config">
    Require all denied
</FilesMatch>

# Block editor backup and temp files (any file)
# Catches: file.php~, file.bak, file.swp, file.save, file.orig, #file#
<FilesMatch "\.(bak|swp|save|orig|old)$|~$|^#.*#$">
    Require all denied
</FilesMatch>

# Block .git and other hidden version control directories
RewriteEngine On
RewriteRule ^\.git - [F,L]

# Block access to submissions and logs directories
RewriteRule ^submissions/ - [F,L]
RewriteRule ^logs/ - [F,L]
