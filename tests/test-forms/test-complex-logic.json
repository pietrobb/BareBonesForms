{
    "$schema": "../forms/form.schema.json",
    "schema_version": 1,
    "id": "test-complex-logic",
    "name": "Complex Conditional Logic Test",
    "description": "Tests chain conditionals, AND/OR conditions, negation, and conditionals inside groups.",
    "submit_label": "Submit",
    "fields": [
        {
            "name": "full_name",
            "type": "text",
            "label": "Full Name",
            "required": true
        },
        {
            "name": "project_type",
            "type": "radio",
            "label": "Project Type",
            "required": true,
            "options": [
                { "value": "Residential", "label": "Residential" },
                { "value": "Commercial", "label": "Commercial" },
                { "value": "Government", "label": "Government" }
            ]
        },
        {
            "name": "company_name",
            "type": "text",
            "label": "Company Name",
            "show_if": { "field": "project_type", "value": "Commercial" }
        },
        {
            "name": "company_vat",
            "type": "text",
            "label": "Company VAT",
            "show_if": {
                "all": [
                    { "field": "project_type", "value": "Commercial" },
                    { "field": "company_name", "op": "not_empty" }
                ]
            }
        },
        {
            "name": "need_installation",
            "type": "radio",
            "label": "Need Installation?",
            "required": true,
            "options": [
                { "value": "Yes", "label": "Yes" },
                { "value": "No", "label": "No" }
            ]
        },
        {
            "name": "need_delivery",
            "type": "radio",
            "label": "Need Delivery?",
            "required": true,
            "options": [
                { "value": "Yes", "label": "Yes" },
                { "value": "No", "label": "No" }
            ]
        },
        {
            "name": "preferred_date",
            "type": "date",
            "label": "Preferred Date",
            "show_if": {
                "all": [
                    { "field": "need_installation", "value": "Yes" },
                    { "field": "need_delivery", "value": "Yes" }
                ]
            }
        },
        {
            "name": "heard_from",
            "type": "checkbox",
            "label": "How did you hear about us?",
            "options": [
                { "value": "Social media", "label": "Social media" },
                { "value": "Friend", "label": "Friend" },
                { "value": "Advertisement", "label": "Advertisement" },
                { "value": "Other", "label": "Other" }
            ]
        },
        {
            "name": "referral_detail",
            "type": "text",
            "label": "Referral Detail",
            "show_if": {
                "any": [
                    { "field": "heard_from", "value": "Friend" },
                    { "field": "heard_from", "value": "Other" }
                ]
            }
        },
        {
            "name": "has_budget",
            "type": "radio",
            "label": "Do you have a budget?",
            "required": true,
            "options": [
                { "value": "Yes", "label": "Yes" },
                { "value": "No", "label": "No" }
            ]
        },
        {
            "name": "budget_amount",
            "type": "number",
            "label": "Budget Amount",
            "show_if": { "field": "has_budget", "value": "No", "op": "not" }
        },
        {
            "name": "contact_method",
            "type": "radio",
            "label": "Preferred Contact Method",
            "required": true,
            "options": [
                { "value": "Email", "label": "Email" },
                { "value": "Phone", "label": "Phone" },
                { "value": "Fax", "label": "Fax" }
            ]
        },
        {
            "name": "contact_row",
            "type": "group",
            "title": "Contact Details",
            "fields": [
                {
                    "name": "contact_email",
                    "type": "email",
                    "label": "Email Address",
                    "required": true
                },
                {
                    "name": "contact_phone",
                    "type": "tel",
                    "label": "Phone Number",
                    "required": true
                },
                {
                    "name": "contact_fax",
                    "type": "tel",
                    "label": "Fax Number",
                    "show_if": { "field": "contact_method", "value": "Fax" }
                }
            ]
        },
        {
            "name": "priority",
            "type": "radio",
            "label": "Priority",
            "required": true,
            "options": [
                { "value": "High", "label": "High" },
                { "value": "Medium", "label": "Medium" },
                { "value": "Low", "label": "Low" }
            ]
        },
        {
            "name": "message",
            "type": "textarea",
            "label": "Message",
            "rows": 3
        }
    ],
    "on_submit": {
        "store": true
    }
}
