{
    "$schema": "form.schema.json",
    "schema_version": 1,
    "id": "newsletter",
    "name": "Newsletter",
    "submit_label": "Subscribe",
    "success_message": "You're in! Check your email.",
    "fields": [
        {
            "name": "email",
            "type": "email",
            "label": "Email",
            "placeholder": "your@email.com",
            "required": true
        }
    ],
    "on_submit": {
        "store": true,
        "confirm_email": {
            "to": "{{email}}",
            "subject": "Welcome to our newsletter!"
        },
        "notify": {
            "to": "admin@example.com",
            "subject": "New subscriber: {{email}}"
        },
        "webhooks": []
    }
}
